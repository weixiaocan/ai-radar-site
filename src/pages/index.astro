---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const daily = await getCollection("daily");
const weekly = await getCollection("weekly");
const dailyArticles = daily
  .filter((entry) => entry.data.published)
  .sort((left, right) => right.data.date.localeCompare(left.data.date));
const weeklyArticles = weekly
  .filter((entry) => entry.data.published)
  .sort((left, right) => right.data.date.localeCompare(left.data.date));
---

<BaseLayout title="AI Radar">
  <div class="eyebrow">Daily intelligence archive</div>
  <h1 class="page-title">AI Radar</h1>
  <p class="page-intro">
    每天自动聚合公开 AI 信息源，沉淀成日报与周报。
  </p>
  <div class="rule"></div>

  <section class="archive-group">
    <h2 class="archive-heading">日报</h2>
    <div class="article-list">
      {dailyArticles.map((article) => (
        <article class="article-card">
          <div class="article-topline">
            <div class="eyebrow">日报</div>
            <div class="meta">{article.data.date}</div>
          </div>
          <h2>
            <a href={`/daily/${article.data.routeSlug}/`}>{article.data.title}</a>
          </h2>
        </article>
      ))}
    </div>
  </section>

  <section class="archive-group">
    <h2 class="archive-heading">周报</h2>
    <div class="article-list">
      {weeklyArticles.map((article) => (
        <article class="article-card">
          <div class="article-topline">
            <div class="eyebrow">周报</div>
            <div class="meta">{article.data.date}</div>
          </div>
          <h2>
            <a href={`/weekly/${article.data.routeSlug}/`}>{article.data.title}</a>
          </h2>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
